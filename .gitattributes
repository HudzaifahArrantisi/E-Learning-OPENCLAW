# ============================================================
# .gitattributes — Force LF line endings for cross-platform dev
# Prevents CRLF (Windows) from breaking scripts on Linux
# ============================================================

# Default: auto-detect (Git will normalize on commit)
* text=auto eol=lf

# Force LF for shell scripts (CRITICAL — breaks on Linux with CRLF)
*.sh        text eol=lf

# Force LF for Dockerfiles
Dockerfile  text eol=lf
*.dockerfile text eol=lf

# Force LF for Go source files
*.go        text eol=lf

# Force LF for environment files
.env        text eol=lf
.env.*      text eol=lf

# Force LF for config files commonly used in Docker/Linux
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.conf      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.json      text eol=lf
*.md        text eol=lf

# Force LF for nginx config
nginx.conf  text eol=lf

# Binary files — don't touch these
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.tar.gz    binary
*.exe       binary
