# Frontend Environment Variables
# Copy this file to .env.local and fill with actual values

# Optional backend base URL override (supports LAN/public domain)
# Keep empty to auto-follow active host.
VITE_API_BASE_URL=http://localhost:8080
# Legacy alias still supported by app runtime
VITE_API_URL=http://localhost:8080
VITE_APP_NAME=STUDENT HUB
VITE_APP_VERSION=1.0.0
