# Database (Supabase PostgreSQL)
DB_DSN=postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[YOUR_REGION].pooler.supabase.com:6543/postgres

JWT_SECRET=your_jwt_secret_here
PORT=8080
UPLOAD_PATH=uploads/

# Pakasir Configuration
PAKASIR_API_KEY=your_pakasir_api_key
PAKASIR_SLUG=nf-student-hub
APP_URL=http://localhost:3000
PAKASIR_BASE_URL=https://app.pakasir.com
PAKASIR_WEBHOOK_URL=http://localhost:8080/api/webhook/pakasir

# QRIS Configuration
QRIS_FEE_PERCENTAGE=0.7
TRANSFER_FEE_PERCENTAGE=0.5
MINIMUM_PAYMENT=10000
MAXIMUM_PAYMENT=10000000
DEFAULT_UKT_AMOUNT=7000000

# OpenClaw Reminder System
OPENCLAW_BASE_URL=http://localhost:9090
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_ID=@tugasreminder
OPENCLAW_CRON_SCHEDULE=0 * * * *
