# ============================================================
# Backend Environment Variables (.env.example)
# Copy this file to .env and fill with your REAL values
#
# USAGE:
#   cp .env.example .env
#   nano .env          ← fill in real values
# ============================================================

# --- Server Configuration ---
PORT=8080
HOST=0.0.0.0
ENV=development
GIN_MODE=release

# --- Database (Supabase PostgreSQL) ---
# Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Use TRANSACTION pooler (port 6543), NOT session pooler (port 5432)
DB_DSN=postgresql://postgres.xxxx:your_password_here@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# --- JWT Configuration ---
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRE=24h

# --- Upload Configuration ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# --- Email Configuration (optional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# --- Pakasir Payment Configuration (optional) ---
PAKASIR_API_KEY=your_pakasir_api_key
PAKASIR_SLUG=nf-student-hub
# ⚠️ On VPS: change to https://e-learning-openclaw.vercel.app
APP_URL=http://localhost:3000
PAKASIR_BASE_URL=https://app.pakasir.com
# ⚠️ On VPS: change localhost to YOUR_VPS_IP
PAKASIR_WEBHOOK_URL=http://localhost:8080/api/webhook/pakasir

# --- QRIS Configuration (optional) ---
QRIS_FEE_PERCENTAGE=0.7
TRANSFER_FEE_PERCENTAGE=0.5
MINIMUM_PAYMENT=10000
MAXIMUM_PAYMENT=10000000
DEFAULT_UKT_AMOUNT=7000000

# --- OpenClaw Reminder System ---
OPENCLAW_BASE_URL=http://localhost:9090
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_ID=@tugasreminder
OPENCLAW_CRON_SCHEDULE=0 * * * *

# --- Features ---
ENABLE_WEBSOCKET=true
ENABLE_CHAT=true
ENABLE_NOTIFICATIONS=true

# --- Logging ---
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# --- CORS ---
# Comma-separated list of extra allowed origins (in addition to localhost and Vercel)
# The backend ALWAYS allows: localhost, e-learning-openclaw.vercel.app, and LAN IPs
# Add any custom domains here if needed
ALLOWED_ORIGINS=https://e-learning-openclaw.vercel.app

# --- Internal API Key (for OpenClaw internal endpoints) ---
INTERNAL_API_KEY=your_internal_api_key_here
NAMA=E-Learning-OPENCLAW
